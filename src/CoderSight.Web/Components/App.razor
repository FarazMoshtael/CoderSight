@using System.Globalization
@inject ISiteSettingsService SettingsService

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName"
      dir="@(CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Vazirmatn:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sora: ['Sora', 'sans-serif'],
                        vazirmatn: ['Vazirmatn', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            blue: '#2563EB',
                            navy: '#020817',
                            dark: '#1A2233',
                            slate: '#64748B',
                        },
                    },
                },
            },
        }
    </script>
    <style>h1:focus,h2:focus,h3:focus,h4:focus,h5:focus,h6:focus{outline:none !important;box-shadow:none !important;}</style>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["CoderSight.Web.styles.css"]" />
    <ImportMap />
    @if (!string.IsNullOrEmpty(_faviconUrl))
    {
        @if (_faviconUrl.EndsWith(".svg", StringComparison.OrdinalIgnoreCase))
        {
            <link rel="icon" type="image/svg+xml" href="@_faviconUrl" />
        }
        else if (_faviconUrl.EndsWith(".ico", StringComparison.OrdinalIgnoreCase))
        {
            <link rel="icon" type="image/x-icon" href="@_faviconUrl" />
        }
        else
        {
            <link rel="icon" type="image/png" href="@_faviconUrl" />
        }
    }
    else
    {
        <link rel="icon" type="image/svg+xml" href="uploads/favicon.svg" />
        <link rel="icon" type="image/png" href="favicon.png" />
    }
    @if (!string.IsNullOrEmpty(_ogImageUrl))
    {
        <meta property="og:image" content="@_ogImageUrl" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
    }
    @if (!string.IsNullOrEmpty(_metaDescription))
    {
        <meta name="description" content="@_metaDescription" />
        <meta property="og:description" content="@_metaDescription" />
    }
    <meta property="og:site_name" content="@_siteName" />
    <HeadOutlet />
    @if (!string.IsNullOrEmpty(_gaId))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@_gaId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@_gaId');
        </script>
    }
</head>

<body class="@(CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "fa" ? "font-vazirmatn" : "font-sora") bg-gray-50 text-brand-navy antialiased">
    <CascadingAuthenticationState>
        <CascadingValue Value="@_siteName" Name="SiteName">
            <Routes />
        </CascadingValue>
    </CascadingAuthenticationState>
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["js/site.js"]"></script>
    <script>
        function csBlurHeadings(){var f=document.activeElement;if(f&&/^H[1-6]$/.test(f.tagName))f.blur();}
        document.addEventListener('DOMContentLoaded',csBlurHeadings);
        document.addEventListener('enhancedload',csBlurHeadings);
        new MutationObserver(csBlurHeadings).observe(document.body,{childList:true,subtree:true});
        setTimeout(csBlurHeadings,100);
        setTimeout(csBlurHeadings,500);
    </script>
</body>

</html>

@code {
    private string? _gaId;
    private string? _faviconUrl;
    private string? _ogImageUrl;
    private string? _metaDescription;
    private string _siteName = "CoderSight";

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.GetAsync();
        _gaId = settings?.GoogleAnalyticsId;
        _faviconUrl = settings?.FaviconUrl;
        _siteName = settings?.SiteName ?? "CoderSight";
        _metaDescription = settings?.DefaultMetaDescription;

        var ogImage = settings?.OgImageUrl ?? settings?.LogoUrl;
        if (!string.IsNullOrEmpty(ogImage))
        {
            if (ogImage.StartsWith("http"))
                _ogImageUrl = ogImage;
            else
            {
                var baseUri = (!string.IsNullOrEmpty(settings?.SiteUrl) ? settings.SiteUrl : "").TrimEnd('/');
                _ogImageUrl = baseUri + (ogImage.StartsWith('/') ? ogImage : "/" + ogImage);
            }
        }
    }
}
