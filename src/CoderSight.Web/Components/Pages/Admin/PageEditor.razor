@page "/admin/pages/edit/{PageId:guid}"
@page "/admin/pages/new"
@layout AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Editor")]
@inject IPageService PageService
@inject BlockRegistry BlockRegistry
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(IsNew ? "New Page" : $"Edit: {pg.Title}") — @SiteName Admin</PageTitle>

<div class="flex justify-between items-center mb-6">
    <div class="flex items-center space-x-3">
        <a href="/admin/pages" class="text-gray-400 hover:text-gray-600">←</a>
        <h1 class="text-xl font-bold text-gray-900">@(IsNew ? "New Page" : "Edit Page")</h1>
        <span class="text-xs px-2 py-1 rounded-full @(pg.Status == CoderSight.Core.Enums.PageStatus.Published ? "bg-green-100 text-green-700" : "bg-yellow-100 text-yellow-700")">
            @pg.Status
        </span>
    </div>
    <div class="flex space-x-2">
        @if (!IsNew)
        {
            <a href="/@pg.Culture/@pg.Slug" target="_blank" class="px-4 py-2 border border-gray-300 rounded-md text-sm text-gray-700 hover:bg-gray-50">
                Preview
            </a>
            @if (pg.Status != CoderSight.Core.Enums.PageStatus.Published)
            {
                <button @onclick="PublishPage" class="px-4 py-2 bg-green-600 text-white rounded-md text-sm hover:bg-green-700">
                    Publish
                </button>
            }
        }
        <button @onclick="SavePage" class="px-4 py-2 bg-indigo-600 text-white rounded-md text-sm hover:bg-indigo-700">
            Save
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="mb-4 px-4 py-3 rounded-md text-sm @(isError ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700")">
        @message
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Page Settings</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                    <input type="text" @bind="pg.Title" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                        <input type="text" @bind="pg.Slug" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Culture</label>
                        <select @bind="pg.Culture" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500">
                            <option value="en">English</option>
                            <option value="fa">فارسی</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
                    <input type="text" @bind="pg.MetaTitle" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" placeholder="Custom browser tab title (optional)" />
                    <p class="text-xs text-gray-400 mt-1">Shown in browser tab and search results. Defaults to page title if empty.</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
                    <textarea @bind="pg.MetaDescription" rows="2" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500"></textarea>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Blocks</h2>
                <span class="text-xs text-gray-400">@pg.Blocks.Count block(s)</span>
            </div>

            <div class="space-y-3">
                @foreach (var block in pg.Blocks.OrderBy(b => b.SortOrder))
                {
                    <div class="border border-gray-200 rounded-lg p-4">
                        <div class="flex justify-between items-center mb-2">
                            <div class="flex items-center space-x-2">
                                <span class="text-xs px-2 py-1 rounded bg-indigo-50 text-indigo-700 font-medium">@block.BlockType</span>
                                <span class="text-xs text-gray-400">#@block.SortOrder</span>
                            </div>
                            <div class="flex space-x-1">
                                <button @onclick="() => MoveBlockUp(block)" class="text-gray-400 hover:text-gray-600 text-sm px-1" disabled="@(block.SortOrder == 0)">↑</button>
                                <button @onclick="() => MoveBlockDown(block)" class="text-gray-400 hover:text-gray-600 text-sm px-1">↓</button>
                                <button @onclick="() => RemoveBlock(block)" class="text-red-400 hover:text-red-600 text-sm px-1">✕</button>
                            </div>
                        </div>
                        <CoderSight.Web.Components.Shared.BlockDataEditor
                            BlockType="@block.BlockType"
                            Data="@block.Data"
                            DataChanged="@(json => { block.Data = json; })" />
                        <CoderSight.Web.Components.Shared.BlockStyleEditor
                            Styles="@block.Styles"
                            StylesChanged="@(json => { block.Styles = json; })" />
                    </div>
                }
            </div>

            <div class="mt-4">
                <button @onclick="ToggleBlockPicker" class="w-full border-2 border-dashed border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-500 hover:border-indigo-400 hover:text-indigo-500 transition-colors">
                    + Add Block
                </button>
            </div>

            @if (showBlockPicker)
            {
                <div class="mt-4 bg-gray-50 rounded-lg p-4">
                    <h3 class="text-sm font-medium text-gray-700 mb-3">Choose a block type</h3>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                        @foreach (var category in BlockRegistry.GetCategories())
                        {
                            <div class="col-span-full text-xs font-medium text-gray-500 uppercase tracking-wider mt-2 first:mt-0">@category</div>
                            @foreach (var blockReg in BlockRegistry.GetByCategory(category))
                            {
                                <button @onclick="() => AddBlock(blockReg.Name)"
                                        class="text-left px-3 py-2 bg-white border border-gray-200 rounded-md hover:border-indigo-400 hover:bg-indigo-50 transition-colors text-sm">
                                    @blockReg.Name
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="space-y-6">
        @if (!IsNew && pg.LocalizationGroupId.HasValue)
        {
            <div class="bg-white rounded-lg border border-gray-200 p-6">
                <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Translations</h2>
                @foreach (var translation in translations)
                {
                    <a href="/admin/pages/edit/@translation.Id" class="block py-2 text-sm text-indigo-600 hover:text-indigo-800">
                        @translation.Culture.ToUpper() — @translation.Title
                    </a>
                }
                @if (!translations.Any(t => t.Culture == (pg.Culture == "en" ? "fa" : "en")))
                {
                    <button @onclick="CreateTranslation" class="mt-2 text-sm text-green-600 hover:text-green-800">
                        + Add @(pg.Culture == "en" ? "Persian" : "English") translation
                    </button>
                }
            </div>
        }

        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">Info</h2>
            <dl class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <dt class="text-gray-500">Created</dt>
                    <dd class="text-gray-900">@pg.CreatedAt.ToString("MMM dd, yyyy")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500">Updated</dt>
                    <dd class="text-gray-900">@pg.UpdatedAt.ToString("MMM dd, yyyy")</dd>
                </div>
                @if (pg.PublishedAt.HasValue)
                {
                    <div class="flex justify-between">
                        <dt class="text-gray-500">Published</dt>
                        <dd class="text-gray-900">@pg.PublishedAt.Value.ToString("MMM dd, yyyy")</dd>
                    </div>
                }
            </dl>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";

    [Parameter] public Guid? PageId { get; set; }

    private Page pg = new();
    private List<Page> translations = [];
    private bool showBlockPicker;
    private string? message;
    private bool isError;

    private bool IsNew => PageId is null;

    protected override async Task OnInitializedAsync()
    {
        if (PageId.HasValue)
        {
            var loaded = await PageService.GetByIdAsync(PageId.Value);
            if (loaded is not null)
            {
                pg = loaded;
                if (pg.LocalizationGroupId.HasValue)
                    translations = (await PageService.GetTranslationsAsync(pg.LocalizationGroupId.Value))
                        .Where(p => p.Id != pg.Id).ToList();
            }
        }
    }

    private async Task SavePage()
    {
        try
        {
            if (IsNew)
            {
                pg.LocalizationGroupId = Guid.NewGuid();
                var created = await PageService.CreateAsync(pg);
                Nav.NavigateTo($"/admin/pages/edit/{created.Id}");
            }
            else
            {
                await PageService.UpdateAsync(pg);
            }
            message = "Page saved successfully.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error saving page: {ex.Message}";
            isError = true;
        }
    }

    private async Task PublishPage()
    {
        if (PageId.HasValue)
        {
            await PageService.PublishAsync(PageId.Value);
            pg.Status = CoderSight.Core.Enums.PageStatus.Published;
            message = "Page published!";
            isError = false;
        }
    }

    private void ToggleBlockPicker() => showBlockPicker = !showBlockPicker;

    private void AddBlock(string blockType)
    {
        pg.Blocks.Add(new PageBlock
        {
            Id = Guid.NewGuid(),
            BlockType = blockType,
            SortOrder = pg.Blocks.Count,
            Data = "{}"
        });
        showBlockPicker = false;
    }

    private void RemoveBlock(PageBlock block)
    {
        pg.Blocks.Remove(block);
        ReorderBlocks();
    }

    private void MoveBlockUp(PageBlock block)
    {
        var sorted = pg.Blocks.OrderBy(b => b.SortOrder).ToList();
        var index = sorted.IndexOf(block);
        if (index > 0)
        {
            (sorted[index].SortOrder, sorted[index - 1].SortOrder) = (sorted[index - 1].SortOrder, sorted[index].SortOrder);
        }
    }

    private void MoveBlockDown(PageBlock block)
    {
        var sorted = pg.Blocks.OrderBy(b => b.SortOrder).ToList();
        var index = sorted.IndexOf(block);
        if (index < sorted.Count - 1)
        {
            (sorted[index].SortOrder, sorted[index + 1].SortOrder) = (sorted[index + 1].SortOrder, sorted[index].SortOrder);
        }
    }

    private void ReorderBlocks()
    {
        var sorted = pg.Blocks.OrderBy(b => b.SortOrder).ToList();
        for (int i = 0; i < sorted.Count; i++)
            sorted[i].SortOrder = i;
    }

    private async Task CreateTranslation()
    {
        if (PageId.HasValue)
        {
            var targetCulture = pg.Culture == "en" ? "fa" : "en";
            var clone = await PageService.CloneForTranslationAsync(PageId.Value, targetCulture);
            Nav.NavigateTo($"/admin/pages/edit/{clone.Id}");
        }
    }
}
