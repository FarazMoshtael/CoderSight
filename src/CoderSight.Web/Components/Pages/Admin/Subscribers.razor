@page "/admin/subscribers"
@layout AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Editor")]
@inject INewsletterService NewsletterService
@rendermode InteractiveServer

<PageTitle>Subscribers — @SiteName Admin</PageTitle>

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Newsletter Subscribers</h1>
        <p class="text-sm text-gray-500 mt-1">@activeCount active subscriber@(activeCount != 1 ? "s" : "")</p>
    </div>
    <div class="flex items-center gap-3">
        <label class="flex items-center gap-2 text-sm text-gray-600">
            <input type="checkbox" @bind="showAll" @bind:after="LoadData" class="rounded border-gray-300 text-brand-blue" />
            Show unsubscribed
        </label>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="mb-4 px-4 py-3 rounded-md text-sm bg-green-50 text-green-700">@message</div>
}

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Email</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Name</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Subscribed</th>
                <th class="text-left px-4 py-3 font-medium text-gray-600">Status</th>
                <th class="text-right px-4 py-3 font-medium text-gray-600">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @if (subscribers.Any())
            {
                @foreach (var sub in subscribers)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-mono text-xs">@sub.Email</td>
                        <td class="px-4 py-3 text-gray-600">@(sub.Name ?? "—")</td>
                        <td class="px-4 py-3 text-gray-500 text-xs">@sub.SubscribedAt.ToString("MMM dd, yyyy")</td>
                        <td class="px-4 py-3">
                            @if (sub.IsActive)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Active</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Unsubscribed</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-right">
                            <button @onclick="() => Delete(sub.Id)" class="text-red-500 hover:text-red-700 text-xs">Delete</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="px-4 py-8 text-center text-gray-400">No subscribers yet.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";

    private List<Subscriber> subscribers = [];
    private int activeCount;
    private bool showAll;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        subscribers = await NewsletterService.GetSubscribersAsync(activeOnly: !showAll);
        activeCount = await NewsletterService.GetActiveCountAsync();
    }

    private async Task Delete(Guid id)
    {
        await NewsletterService.DeleteAsync(id);
        message = "Subscriber removed.";
        await LoadData();
    }
}
