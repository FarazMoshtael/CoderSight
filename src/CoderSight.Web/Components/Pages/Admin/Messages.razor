@page "/admin/messages"
@layout AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Editor")]
@inject IContactService ContactService
@rendermode InteractiveServer

<PageTitle>Messages — @SiteName Admin</PageTitle>

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Contact Messages</h1>
        <p class="text-sm text-gray-500 mt-1">@unreadCount unread message@(unreadCount != 1 ? "s" : "")</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="mb-4 px-4 py-3 rounded-md text-sm bg-green-50 text-green-700">@statusMessage</div>
}

@if (messages.Any())
{
    <div class="space-y-3">
        @foreach (var msg in messages)
        {
            <div class="bg-white rounded-lg border @(msg.IsRead ? "border-gray-200" : "border-brand-blue border-l-4") p-5">
                <div class="flex justify-between items-start">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-1">
                            <span class="font-medium text-sm text-gray-900">@msg.Name</span>
                            <a href="mailto:@msg.Email" class="text-xs text-brand-blue hover:underline font-mono">@msg.Email</a>
                            @if (!msg.IsRead)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-blue-100 text-blue-800">New</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(msg.Subject))
                        {
                            <p class="text-sm font-medium text-gray-700 mb-1">@msg.Subject</p>
                        }
                        <p class="text-sm text-gray-600 whitespace-pre-wrap leading-relaxed">@msg.Message</p>
                        <div class="flex items-center gap-3 mt-3">
                            <span class="text-xs text-gray-400">@msg.SubmittedAt.ToString("MMM dd, yyyy — HH:mm")</span>
                            @if (!string.IsNullOrEmpty(msg.PageSlug))
                            {
                                <span class="text-xs text-gray-400">from: @msg.PageSlug</span>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-2 ms-4">
                        @if (!msg.IsRead)
                        {
                            <button @onclick="() => MarkRead(msg.Id)" class="text-xs text-gray-500 hover:text-brand-blue">Mark read</button>
                        }
                        <button @onclick="() => Delete(msg.Id)" class="text-xs text-gray-400 hover:text-red-600">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
        <p class="text-gray-400 text-sm">No messages yet.</p>
    </div>
}

@code {
    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";

    private List<ContactMessage> messages = [];
    private int unreadCount;
    private string? statusMessage;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        messages = await ContactService.GetAllAsync();
        unreadCount = await ContactService.GetUnreadCountAsync();
    }

    private async Task MarkRead(Guid id)
    {
        await ContactService.MarkAsReadAsync(id);
        await LoadData();
    }

    private async Task Delete(Guid id)
    {
        await ContactService.DeleteAsync(id);
        statusMessage = "Message deleted.";
        await LoadData();
    }
}
