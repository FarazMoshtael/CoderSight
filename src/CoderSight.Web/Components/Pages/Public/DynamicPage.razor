@page "/{culture}/{*slug}"
@page "/{*slug}"
@inject IPageService PageService
@inject IBlogService BlogService
@inject ISiteSettingsService SettingsService
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager
@using CoderSight.Data
@using CoderSight.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Identity

<PageTitle>@(currentPage?.MetaTitle ?? currentPage?.Title ?? _siteName)</PageTitle>

@if (currentPage is not null)
{
    <HeadContent>
        <meta name="description" content="@_metaDescription" />
        <link rel="canonical" href="@_canonicalUrl" />

        <!-- Open Graph -->
        <meta property="og:type" content="@(blogPost is not null ? "article" : "website")" />
        <meta property="og:title" content="@_metaTitle" />
        <meta property="og:description" content="@_metaDescription" />
        <meta property="og:url" content="@_canonicalUrl" />
        <meta property="og:site_name" content="@_siteName" />
        @if (!string.IsNullOrEmpty(_ogImage))
        {
            <meta property="og:image" content="@_ogImage" />
            <meta property="og:image:width" content="1200" />
            <meta property="og:image:height" content="630" />
        }
        @if (blogPost is not null)
        {
            @if (!string.IsNullOrEmpty(blogPost.AuthorName))
            {
                <meta property="article:author" content="@blogPost.AuthorName" />
            }
            @if (currentPage.PublishedAt.HasValue)
            {
                <meta property="article:published_time" content="@currentPage.PublishedAt.Value.ToString("o")" />
            }
            <meta property="article:modified_time" content="@currentPage.UpdatedAt.ToString("o")" />
        }

        <!-- Twitter Card -->
        <meta name="twitter:card" content="@(!string.IsNullOrEmpty(_ogImage) ? "summary_large_image" : "summary")" />
        <meta name="twitter:title" content="@_metaTitle" />
        <meta name="twitter:description" content="@_metaDescription" />
        @if (!string.IsNullOrEmpty(_ogImage))
        {
            <meta name="twitter:image" content="@_ogImage" />
        }
    </HeadContent>
}

@if (currentPage is null)
{
    @if (loading)
    {
        <div class="flex justify-center items-center min-h-[50vh]">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-brand-blue"></div>
        </div>
    }
    else
    {
        <div class="max-w-2xl mx-auto py-20 text-center">
            <h1 class="text-4xl font-bold text-gray-900 mb-4">404</h1>
            <p class="text-gray-600 text-lg">@(_resolvedCulture == "fa" ? "صفحه مورد نظر یافت نشد" : "Page not found")</p>
            <a href="/" class="mt-6 inline-block text-brand-blue hover:opacity-80">
                @(_resolvedCulture == "fa" ? "→ بازگشت به خانه" : "← Back to home")
            </a>
        </div>
    }
}
else
{
    @if (blogPost is not null)
    {
        <!-- Blog post header with meta -->
        <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <header class="pt-10 pb-6">
                @if (blogPost.BlogPostCategories.Any())
                {
                    <div class="flex flex-wrap gap-2 mb-3">
                        @foreach (var bc in blogPost.BlogPostCategories)
                        {
                            <a href="@_linkPrefix/blog?category=@bc.Category.Slug"
                               class="text-xs font-medium bg-blue-50 text-brand-blue px-2.5 py-1 rounded-full hover:bg-blue-100 transition-colors">
                                @bc.Category.Name
                            </a>
                        }
                    </div>
                }

                <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">@currentPage.Title</h1>

                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mb-6">
                    @if (!string.IsNullOrEmpty(blogPost.AuthorName))
                    {
                        <a href="/author/@blogPost.AuthorId" class="flex items-center gap-2 hover:opacity-80 transition-opacity" data-enhance-nav="false">
                            @if (!string.IsNullOrEmpty(blogPost.AuthorAvatarUrl))
                            {
                                <img src="@blogPost.AuthorAvatarUrl" alt="@blogPost.AuthorName" class="w-6 h-6 rounded-full object-cover" />
                            }
                            <span class="font-medium text-gray-700 hover:text-brand-blue transition-colors">@blogPost.AuthorName</span>
                        </a>
                    }
                    @if (currentPage.PublishedAt.HasValue)
                    {
                        <span>@currentPage.PublishedAt.Value.ToString("MMM d, yyyy")</span>
                    }
                    @if (blogPost.ReadTimeMinutes > 0)
                    {
                        <span>@blogPost.ReadTimeMinutes min read</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(blogPost.FeaturedImageUrl))
                {
                    <img src="@blogPost.FeaturedImageUrl" alt="@currentPage.Title" class="w-full rounded-xl object-cover max-h-96 mb-6" />
                }
            </header>
        </article>
    }

    <BlockRenderer Blocks="currentPage.Blocks" />

    @if (blogPost is not null)
    {
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
            <!-- Author bio -->
            @if (!string.IsNullOrEmpty(blogPost.AuthorName) && !string.IsNullOrEmpty(blogPost.AuthorBio))
            {
                <div class="border-t border-gray-200 pt-8 mt-8">
                    <div class="flex items-start gap-4">
                        @if (!string.IsNullOrEmpty(blogPost.AuthorAvatarUrl))
                        {
                            <a href="/author/@blogPost.AuthorId" data-enhance-nav="false">
                                <img src="@blogPost.AuthorAvatarUrl" alt="@blogPost.AuthorName" class="w-14 h-14 rounded-full object-cover shrink-0 hover:opacity-80 transition-opacity" />
                            </a>
                        }
                        <div>
                            <a href="/author/@blogPost.AuthorId" class="font-semibold text-gray-900 mb-1 inline-block hover:text-brand-blue transition-colors" data-enhance-nav="false">@blogPost.AuthorName</a>
                            <p class="text-sm text-gray-600">@blogPost.AuthorBio</p>
                            @if (!string.IsNullOrEmpty(blogPost.AuthorLinkedIn) || !string.IsNullOrEmpty(blogPost.AuthorTwitter) || !string.IsNullOrEmpty(blogPost.AuthorWebsite))
                            {
                                <div class="flex items-center gap-3 mt-2">
                                    @if (!string.IsNullOrEmpty(blogPost.AuthorLinkedIn))
                                    {
                                        <a href="@EnsureAbsoluteUrl(blogPost.AuthorLinkedIn)" target="_blank" rel="noopener noreferrer" class="text-brand-slate hover:text-brand-blue transition-colors" title="LinkedIn">
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(blogPost.AuthorTwitter))
                                    {
                                        <a href="@EnsureAbsoluteUrl(blogPost.AuthorTwitter)" target="_blank" rel="noopener noreferrer" class="text-brand-slate hover:text-brand-blue transition-colors" title="Twitter / X">
                                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(blogPost.AuthorWebsite))
                                    {
                                        <a href="@EnsureAbsoluteUrl(blogPost.AuthorWebsite)" target="_blank" rel="noopener noreferrer" class="text-brand-slate hover:text-brand-blue transition-colors" title="Website">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Tags -->
            @if (blogPost.BlogPostTags.Any())
            {
                <div class="border-t border-gray-200 pt-6 mt-8">
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="text-sm font-medium text-gray-500 me-1">
                            @(_resolvedCulture == "fa" ? "برچسب‌ها:" : "Tags:")
                        </span>
                        @foreach (var bt in blogPost.BlogPostTags)
                        {
                            <a href="@_linkPrefix/blog?tag=@bt.Tag.Slug"
                               class="text-xs border border-gray-300 text-gray-600 px-2.5 py-1 rounded-full hover:border-brand-blue hover:text-brand-blue transition-colors">
                                @bt.Tag.Name
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Comments -->
        <CoderSight.Web.Components.Blocks.CommentsBlock BlogPostId="blogPost.Id" />
    }
}

@code {
    [Parameter] public string? Culture { get; set; }
    [Parameter] public string? Slug { get; set; }

    private Page? currentPage;
    private BlogPost? blogPost;
    private bool loading = true;
    private string _resolvedCulture = "en";

    private string _metaTitle = "";
    private string _metaDescription = "";
    private string _canonicalUrl = "";
    private string _ogImage = "";
    private string _siteName = "CoderSight";
    private bool _isMultilingual = true;
    private string _linkPrefix => _isMultilingual ? $"/{_resolvedCulture}" : "";

    private static readonly HashSet<string> KnownCultures = new(StringComparer.OrdinalIgnoreCase) { "en", "fa" };

    protected override async Task OnParametersSetAsync()
    {
        loading = true;

        var settings = await SettingsService.GetAsync();
        var defaultCulture = settings?.DefaultCulture ?? "en";
        _isMultilingual = settings?.EnableMultilingual ?? true;

        var hasCultureSegment = !string.IsNullOrEmpty(Culture) && KnownCultures.Contains(Culture);

        string effectiveSlug;
        if (hasCultureSegment)
        {
            _resolvedCulture = Culture!;
            effectiveSlug = Slug ?? string.Empty;

            if (!_isMultilingual)
            {
                Nav.NavigateTo(string.IsNullOrEmpty(effectiveSlug) ? "/" : $"/{effectiveSlug}", replace: true);
                return;
            }
        }
        else
        {
            _resolvedCulture = defaultCulture;
            effectiveSlug = string.IsNullOrEmpty(Slug)
                ? (Culture ?? string.Empty)
                : $"{Culture}/{Slug}";

            if (_isMultilingual)
            {
                var target = string.IsNullOrEmpty(effectiveSlug) ? $"/{defaultCulture}/" : $"/{defaultCulture}/{effectiveSlug}";
                Nav.NavigateTo(target, replace: true);
                return;
            }
        }

        currentPage = await PageService.GetBySlugAsync(effectiveSlug, _resolvedCulture);

        if (currentPage is not null)
        {
            blogPost = await BlogService.GetByPageIdAsync(currentPage.Id);
            if (blogPost is not null)
                await RefreshAuthorFromProfile();
            await BuildMeta();
        }
        else
        {
            blogPost = null;
        }

        loading = false;
    }

    private async Task RefreshAuthorFromProfile()
    {
        if (blogPost is null || string.IsNullOrEmpty(blogPost.AuthorId))
            return;

        var author = await UserManager.FindByIdAsync(blogPost.AuthorId);
        if (author is null)
            return;

        blogPost.AuthorName = author.DisplayName;
        blogPost.AuthorAvatarUrl = author.AvatarUrl;
        blogPost.AuthorBio = author.Bio;
        blogPost.AuthorLinkedIn = author.LinkedIn;
        blogPost.AuthorTwitter = author.Twitter;
        blogPost.AuthorWebsite = author.Website;
    }

    private static string EnsureAbsoluteUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "#";
        if (url.StartsWith("http://") || url.StartsWith("https://")) return url;
        return "https://" + url;
    }

    private async Task BuildMeta()
    {
        var settings = await SettingsService.GetAsync();
        _siteName = settings?.SiteName ?? "CoderSight";

        _metaTitle = currentPage!.MetaTitle ?? currentPage.Title;
        _metaDescription = blogPost is not null
            ? (blogPost.Excerpt ?? currentPage.MetaDescription ?? settings?.DefaultMetaDescription ?? "")
            : (currentPage.MetaDescription ?? settings?.DefaultMetaDescription ?? "");

        var baseUri = (!string.IsNullOrEmpty(settings?.SiteUrl) ? settings.SiteUrl : Nav.BaseUri).TrimEnd('/');
        _canonicalUrl = _isMultilingual
            ? $"{baseUri}/{_resolvedCulture}/{currentPage.Slug}"
            : $"{baseUri}/{currentPage.Slug}";

        if (blogPost is not null && !string.IsNullOrEmpty(blogPost.FeaturedImageUrl))
            _ogImage = blogPost.FeaturedImageUrl.StartsWith("http")
                ? blogPost.FeaturedImageUrl
                : $"{baseUri}{blogPost.FeaturedImageUrl}";
        else
        {
            var fallbackImage = settings?.OgImageUrl ?? settings?.LogoUrl;
            if (!string.IsNullOrEmpty(fallbackImage))
                _ogImage = fallbackImage.StartsWith("http")
                    ? fallbackImage
                    : $"{baseUri}{fallbackImage}";
        }
    }
}
