@page "/author/{AuthorId}"
@inject UserManager<ApplicationUser> UserManager
@inject IBlogService BlogService
@inject ISiteSettingsService SettingsService
@using Microsoft.AspNetCore.Identity
@using CoderSight.Data

<PageTitle>@(author?.DisplayName ?? "Author") — @SiteName</PageTitle>

@if (author is null)
{
    <div class="min-h-[50vh] flex items-center justify-center">
        <div class="text-center">
            <h1 class="text-2xl font-bold" style="color: #020817;">Author Not Found</h1>
            <p class="text-sm mt-2" style="color: #64748B;">The author you're looking for doesn't exist.</p>
            <a href="/" class="inline-block mt-4 text-sm font-semibold hover:underline" style="color: #2563EB;">Back to Home</a>
        </div>
    </div>
}
else
{
    <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <!-- Author header -->
        <div class="text-center mb-12">
            @if (!string.IsNullOrEmpty(author.AvatarUrl))
            {
                <img src="@author.AvatarUrl" alt="@author.DisplayName" class="w-24 h-24 rounded-full object-cover mx-auto mb-4 border-2 border-gray-200" />
            }
            else
            {
                <div class="w-24 h-24 rounded-full bg-gray-200 flex items-center justify-center text-3xl font-bold mx-auto mb-4" style="color: #64748B;">
                    @author.DisplayName[..1].ToUpper()
                </div>
            }
            <h1 class="text-2xl font-bold" style="color: #020817;">@author.DisplayName</h1>
            @if (!string.IsNullOrEmpty(author.Bio))
            {
                <p class="text-sm mt-2 max-w-lg mx-auto" style="color: #64748B;">@author.Bio</p>
            }
            @if (!string.IsNullOrEmpty(author.LinkedIn) || !string.IsNullOrEmpty(author.Twitter) || !string.IsNullOrEmpty(author.Website))
            {
                <div class="flex items-center justify-center gap-4 mt-4">
                    @if (!string.IsNullOrEmpty(author.LinkedIn))
                    {
                        <a href="@EnsureAbsoluteUrl(author.LinkedIn)" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: #64748B;" onmouseover="this.style.color='#2563EB'" onmouseout="this.style.color='#64748B'" title="LinkedIn">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(author.Twitter))
                    {
                        <a href="@EnsureAbsoluteUrl(author.Twitter)" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: #64748B;" onmouseover="this.style.color='#2563EB'" onmouseout="this.style.color='#64748B'" title="Twitter / X">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(author.Website))
                    {
                        <a href="@EnsureAbsoluteUrl(author.Website)" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: #64748B;" onmouseover="this.style.color='#2563EB'" onmouseout="this.style.color='#64748B'" title="Website">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Posts by this author -->
        @if (posts.Any())
        {
            <h2 class="text-lg font-semibold mb-6" style="color: #020817;">
                Articles by @author.DisplayName
                <span class="text-sm font-normal" style="color: #64748B;">(@posts.Count)</span>
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var post in posts)
                {
                    var postUrl = isMultilingual ? $"/{post.Page.Culture}/{post.Page.Slug}" : $"/{post.Page.Slug}";
                    <a href="@postUrl" class="group block bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
                        @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
                        {
                            <div class="aspect-[16/9] overflow-hidden">
                                <img src="@post.FeaturedImageUrl" alt="@post.Page.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                            </div>
                        }
                        <div class="p-4">
                            @if (post.BlogPostCategories.Any())
                            {
                                <p class="text-xs font-medium mb-2" style="color: #2563EB;">
                                    @string.Join(", ", post.BlogPostCategories.Select(bc => bc.Category.Name))
                                </p>
                            }
                            <h3 class="font-semibold text-sm leading-snug mb-2 group-hover:text-brand-blue transition-colors" style="color: #020817;">@post.Page.Title</h3>
                            @if (!string.IsNullOrEmpty(post.Excerpt))
                            {
                                <p class="text-xs line-clamp-2" style="color: #64748B;">@post.Excerpt</p>
                            }
                            <div class="flex items-center gap-3 mt-3 text-xs" style="color: #64748B;">
                                @if (post.Page.PublishedAt.HasValue)
                                {
                                    <span>@post.Page.PublishedAt.Value.ToString("MMM d, yyyy")</span>
                                }
                                @if (post.ReadTimeMinutes > 0)
                                {
                                    <span>@post.ReadTimeMinutes min read</span>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <p class="text-sm" style="color: #64748B;">No published articles yet.</p>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string AuthorId { get; set; } = "";

    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";

    private ApplicationUser? author;
    private List<BlogPost> posts = [];
    private bool isMultilingual;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.GetAsync();
        isMultilingual = settings?.EnableMultilingual ?? true;

        author = await UserManager.FindByIdAsync(AuthorId);
        if (author is not null)
            posts = await BlogService.GetPublishedByAuthorAsync(AuthorId);
    }

    private static string EnsureAbsoluteUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "#";
        if (url.StartsWith("http://") || url.StartsWith("https://")) return url;
        return "https://" + url;
    }
}
