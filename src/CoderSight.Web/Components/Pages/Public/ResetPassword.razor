@page "/reset-password"
@inject ISiteSettingsService SettingsService

<PageTitle>Set New Password — @SiteName</PageTitle>

<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold" style="color: #020817;">Set New Password</h1>
            <p class="text-sm mt-2" style="color: #64748B;">Choose a new password for your account.</p>
        </div>

        @if (Status == "success")
        {
            <div class="px-4 py-3 rounded-md text-sm bg-green-50 text-green-700 mb-4">
                Your password has been reset successfully.
            </div>
            <p class="text-center text-sm mt-4">
                <a href="/login" class="font-semibold hover:underline" style="color: #2563EB;">Sign In</a>
            </p>
        }
        else if (Status == "invalid")
        {
            <div class="px-4 py-3 rounded-md text-sm bg-red-50 text-red-700 mb-4">
                This reset link is invalid or has expired. Please request a new one.
            </div>
            <p class="text-center text-sm mt-4">
                <a href="/forgot-password" class="font-semibold hover:underline" style="color: #2563EB;">Request New Link</a>
            </p>
        }
        else
        {
            @if (Status == "captcha")
            {
                <div class="mb-4 px-4 py-3 rounded-md text-sm bg-red-50 text-red-700">
                    Please complete the verification challenge.
                </div>
            }
            else if (Status == "error")
            {
                <div class="mb-4 px-4 py-3 rounded-md text-sm bg-red-50 text-red-700">
                    @(ErrorDetail ?? "Failed to reset password. Please check the requirements and try again.")
                </div>
            }

            <form method="post" action="/api/auth/reset-password" data-enhance="false">
                <input type="hidden" name="email" value="@Email" />
                <input type="hidden" name="token" value="@Token" />

                <div style="position:absolute;left:-9999px;" aria-hidden="true"><textarea name="cs_hp" tabindex="-1" autocomplete="off" rows="1"></textarea></div>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1" style="color: #020817;">New Password</label>
                        <input type="password" name="password" required minlength="8"
                               class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2"
                               style="border-color: #64748B40; color: #020817;"
                               placeholder="Minimum 8 characters" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1" style="color: #020817;">Confirm Password</label>
                        <input type="password" name="confirmPassword" required minlength="8"
                               class="w-full border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2"
                               style="border-color: #64748B40; color: #020817;" />
                    </div>
                    @if (!string.IsNullOrEmpty(TurnstileSiteKey))
                    {
                        <div class="cf-turnstile" data-sitekey="@TurnstileSiteKey" data-theme="light" data-size="flexible"></div>
                    }
                    <button type="submit" class="w-full text-white py-2.5 rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity"
                            style="background-color: #2563EB;">
                        Reset Password
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "detail")]
    public string? ErrorDetail { get; set; }

    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";

    [CascadingParameter(Name = "TurnstileSiteKey")]
    private string? TurnstileSiteKey { get; set; }
}
