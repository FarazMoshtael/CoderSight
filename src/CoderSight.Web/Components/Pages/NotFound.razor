@page "/not-found"
@layout EmptyLayout

<PageTitle>Page Not Found — @SiteName</PageTitle>

<div class="min-h-screen bg-brand-navy flex flex-col items-center justify-center px-4 text-white font-sora">

    <!-- Logo mark -->
    <div class="mb-10">
        <img src="/uploads/logo-icon.svg" alt="CoderSight" class="h-16 w-auto opacity-90" />
    </div>

    <!-- 404 with icon -->
    <div class="relative mb-6">
        <span class="text-[8rem] leading-none font-bold text-brand-blue opacity-10 select-none">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
            <svg class="w-16 h-16 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.318M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
            </svg>
        </div>
    </div>

    <h1 class="text-2xl sm:text-3xl font-semibold text-white mb-3 text-center">
        Page not found
    </h1>
    <p class="text-brand-slate text-center max-w-md mb-8 text-sm sm:text-base leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
        <a href="/" class="inline-flex items-center justify-center gap-2 bg-brand-blue text-white px-6 py-3 rounded-lg font-medium hover:opacity-90 transition-opacity">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Go Home
        </a>
        <a href="/en/blog" class="inline-flex items-center justify-center gap-2 border border-white/20 text-white px-6 py-3 rounded-lg font-medium hover:bg-white/5 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            Browse Blog
        </a>
    </div>

    <p class="mt-12 text-xs text-white/20">@SiteName</p>
</div>

@code {
    [CascadingParameter(Name = "SiteName")]
    private string SiteName { get; set; } = "CoderSight";
}
