@using CoderSight.Core.Blocks.Data

<section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
        @if (!string.IsNullOrEmpty(Data?.SectionTitle))
        {
            <h2 class="text-3xl font-bold text-center text-brand-navy mb-12">@Data.SectionTitle</h2>
        }
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-@(Data?.Columns ?? 4) gap-8">
            @if (Data?.Members is not null)
            {
                @foreach (var member in Data.Members)
                {
                    <div class="text-center">
                        @if (!string.IsNullOrEmpty(member.ImageUrl))
                        {
                            <img src="@member.ImageUrl" alt="@member.Name" class="w-24 h-24 rounded-full mx-auto mb-4 object-cover" />
                        }
                        else
                        {
                            <div class="w-24 h-24 rounded-full mx-auto mb-4 bg-brand-navy text-white flex items-center justify-center text-2xl font-bold">
                                @member.Name[..1]
                            </div>
                        }
                        <h3 class="font-semibold text-brand-navy">@member.Name</h3>
                        <p class="text-sm text-brand-blue mb-2">@member.Role</p>
                        @if (!string.IsNullOrEmpty(member.Bio))
                        {
                            <p class="text-sm text-brand-slate">@member.Bio</p>
                        }
                        @if (!string.IsNullOrEmpty(member.LinkedInUrl) || !string.IsNullOrEmpty(member.TwitterUrl))
                        {
                            <div class="flex justify-center gap-3 mt-3">
                                @if (!string.IsNullOrEmpty(member.LinkedInUrl))
                                {
                                    <a href="@EnsureAbsoluteUrl(member.LinkedInUrl)" target="_blank" rel="noopener noreferrer" class="text-brand-slate hover:text-brand-blue transition-colors" title="LinkedIn">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(member.TwitterUrl))
                                {
                                    <a href="@EnsureAbsoluteUrl(member.TwitterUrl)" target="_blank" rel="noopener noreferrer" class="text-brand-slate hover:text-brand-blue transition-colors" title="Twitter / X">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public TeamBlockData? Data { get; set; }

    private static string EnsureAbsoluteUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "#";
        if (url.StartsWith("http://") || url.StartsWith("https://")) return url;
        return "https://" + url;
    }
}
