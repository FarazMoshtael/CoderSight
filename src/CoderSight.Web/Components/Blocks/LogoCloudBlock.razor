@using CoderSight.Core.Blocks.Data

<section class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
        @if (!string.IsNullOrEmpty(Data?.Title))
        {
            <p class="text-center text-sm text-gray-500 mb-8">@Data.Title</p>
        }
        <div class="flex justify-center items-center flex-wrap gap-12">
            @if (Data?.Logos is not null)
            {
                @foreach (var logo in Data.Logos)
                {
                    <a href="@logo.Link" class="opacity-50 hover:opacity-100 transition-opacity">
                        <div class="h-10 w-32 bg-gray-300 rounded flex items-center justify-center text-xs text-gray-500">
                            @logo.AltText
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public LogoCloudBlockData? Data { get; set; }
}
