@using CoderSight.Core.Blocks.Data

@{
    var ctaBg = Data?.BackgroundColor ?? "#2563EB";
    var ctaStyle = ctaBg == "#2563EB"
        ? $"background-color: {ctaBg};"
        : $"background: linear-gradient(135deg, {ctaBg}, #1A2233);";
}
<section class="py-12 sm:py-16 px-4" style="@ctaStyle">
    <div class="max-w-3xl mx-auto text-center text-white">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">@Data?.Title</h2>
        @if (!string.IsNullOrEmpty(Data?.Description))
        {
            <p class="text-sm sm:text-lg text-white/80 mb-8 max-w-xl mx-auto">@Data.Description</p>
        }
        <a href="@Data?.ButtonLink"
           class="inline-block bg-white text-brand-blue px-6 sm:px-8 py-2.5 sm:py-3 rounded-lg font-semibold text-sm sm:text-base hover:bg-gray-100 transition-colors">
            @Data?.ButtonText
        </a>
    </div>
</section>

@code {
    [Parameter] public CallToActionBlockData? Data { get; set; }
}
