@using CoderSight.Core.Blocks.Data

<section class="py-6 px-4">
    <div class="max-w-3xl mx-auto bg-gray-50 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3">@(Data?.Title ?? "Table of Contents")</h3>
        <p class="text-sm text-gray-500">Auto-generated from page headings (h@(Data?.MinHeadingLevel ?? 2)–h@(Data?.MaxHeadingLevel ?? 3)).</p>
    </div>
</section>

@code {
    [Parameter] public TableOfContentsBlockData? Data { get; set; }
}
