@using CoderSight.Core.Blocks.Data

<section class="py-16 px-4">
    <div class="max-w-2xl mx-auto">
        @if (!string.IsNullOrEmpty(Data?.Title))
        {
            <h2 class="text-2xl font-bold text-gray-900 mb-2">@Data.Title</h2>
        }
        @if (!string.IsNullOrEmpty(Data?.Description))
        {
            <p class="text-gray-600 mb-8">@Data.Description</p>
        }
        <form onsubmit="return csContactSubmit(this)" class="space-y-4">

            <div style="position:absolute;left:-9999px;" aria-hidden="true"><textarea name="cs_hp" tabindex="-1" autocomplete="off" rows="1"></textarea></div>
            @if (Data?.Fields is not null && Data.Fields.Any())
            {
                @foreach (var field in Data.Fields)
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            @field.Label @(field.Required ? "*" : "")
                        </label>
                        @if (field.Type == "textarea")
                        {
                            <textarea rows="4" name="@GetFieldName(field)" placeholder="@field.Placeholder"
                                      @(field.Required ? "required" : "")
                                      class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-brand-blue"></textarea>
                        }
                        else
                        {
                            <input type="@field.Type" name="@GetFieldName(field)" placeholder="@field.Placeholder"
                                   @(field.Required ? "required" : "")
                                   class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-brand-blue" />
                        }
                    </div>
                }
            }
            else
            {
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                    <input type="text" name="name" required class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                    <input type="email" name="email" required class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                    <input type="text" name="subject" class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
                    <textarea rows="4" name="message" required class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue"></textarea>
                </div>
            }
            @if (!string.IsNullOrEmpty(TurnstileSiteKey))
            {
                <div class="cf-turnstile" data-sitekey="@TurnstileSiteKey" data-theme="light"></div>
            }
            <div>
                <button type="submit"
                        class="w-full sm:w-auto bg-brand-blue text-white px-6 py-2.5 rounded-md font-medium hover:opacity-90 transition-opacity">
                    @(Data?.SubmitButtonText ?? "Send message")
                </button>
            </div>
            <p class="cs-contact-msg text-sm hidden"></p>
        </form>
    </div>
</section>

@code {
    [Parameter] public ContactFormBlockData? Data { get; set; }

    [CascadingParameter(Name = "TurnstileSiteKey")]
    private string? TurnstileSiteKey { get; set; }

    private string GetFieldName(FormField field)
    {
        var label = field.Label.ToLowerInvariant();
        if (label.Contains("email")) return "email";
        if (label.Contains("name")) return "name";
        if (label.Contains("subject")) return "subject";
        if (field.Type == "textarea" || label.Contains("message") || label.Contains("comment")) return "message";
        return field.Label.ToLowerInvariant().Replace(" ", "_");
    }
}
