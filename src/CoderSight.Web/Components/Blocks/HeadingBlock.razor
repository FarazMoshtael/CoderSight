@using CoderSight.Core.Blocks.Data

<section class="py-12 px-4 text-@(Data?.Alignment ?? "center")">
    <div class="max-w-4xl mx-auto">
        @switch (Data?.Level)
        {
            case "h1":
                <h1 class="text-4xl font-bold text-brand-navy mb-2">@Data?.Text</h1>
                break;
            case "h3":
                <h3 class="text-2xl font-bold text-brand-navy mb-2">@Data?.Text</h3>
                break;
            default:
                <h2 class="text-3xl font-bold text-brand-navy mb-2">@Data?.Text</h2>
                break;
        }
        @if (!string.IsNullOrEmpty(Data?.Subtitle))
        {
            <p class="text-lg text-brand-slate max-w-2xl @(Data?.Alignment == "center" ? "mx-auto" : "")">@Data.Subtitle</p>
        }
    </div>
</section>

@code {
    [Parameter] public HeadingBlockData? Data { get; set; }
}
