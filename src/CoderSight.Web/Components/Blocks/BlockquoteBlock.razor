@using CoderSight.Core.Blocks.Data

<section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
        <blockquote class="border-s-4 border-indigo-500 ps-6 py-4 bg-gray-50 rounded-e-lg">
            <p class="text-xl text-gray-700 italic">@Data?.Quote</p>
            @if (!string.IsNullOrEmpty(Data?.Attribution))
            {
                <footer class="mt-3 text-sm text-gray-500">— @Data.Attribution</footer>
            }
        </blockquote>
    </div>
</section>

@code {
    [Parameter] public BlockquoteBlockData? Data { get; set; }
}
