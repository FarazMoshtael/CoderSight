@inject IMediaService MediaService

@if (IsVisible)
{
    <!-- Backdrop -->
    <div class="fixed inset-0 z-[100] bg-black/50" @onclick="Close"></div>

    <!-- Modal -->
    <div class="fixed inset-4 sm:inset-auto sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 z-[101] bg-white rounded-xl shadow-2xl sm:w-full sm:max-w-3xl sm:max-h-[80vh] flex flex-col">
        <!-- Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 shrink-0">
            <h2 class="text-lg font-semibold text-gray-900">Select Media</h2>
            <button @onclick="Close" type="button" class="text-gray-400 hover:text-gray-600 p-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Upload area -->
        <div class="px-6 pt-4 shrink-0">
            <label class="block border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-brand-blue transition-colors cursor-pointer">
                <InputFile OnChange="HandleUpload" class="block mx-auto text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-4 file:rounded file:border-0 file:text-sm file:font-medium file:bg-brand-blue file:text-white hover:file:opacity-90" accept="image/*,video/*,.pdf,.svg" />
                <p class="text-xs text-gray-400 mt-2">Images, videos, PDFs, SVGs (max 10 MB)</p>
            </label>
            @if (uploading)
            {
                <p class="text-xs mt-2 text-brand-blue animate-pulse">Uploading...</p>
            }
            else if (!string.IsNullOrEmpty(uploadMessage))
            {
                <p class="text-xs mt-2 @(uploadError ? "text-red-600" : "text-green-600")">@uploadMessage</p>
            }
        </div>

        <!-- Media grid -->
        <div class="flex-1 overflow-y-auto px-6 py-4 min-h-0">
            @if (mediaItems.Any())
            {
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
                    @foreach (var item in mediaItems)
                    {
                        var isSelected = item.Url == selectedUrl;
                        <button @onclick="() => SelectItem(item)" type="button"
                                class="group relative rounded-lg overflow-hidden border-2 transition-all hover:shadow-md @(isSelected ? "border-brand-blue ring-2 ring-brand-blue/30" : "border-gray-200 hover:border-gray-300")">
                            @if (item.ContentType.StartsWith("image/"))
                            {
                                <img src="@($"{item.Url}?v={cacheBust}")" alt="@(item.AltText ?? item.FileName)" class="w-full h-24 object-cover" loading="lazy" />
                            }
                            else
                            {
                                <div class="w-full h-24 bg-gray-100 flex flex-col items-center justify-center text-gray-400">
                                    <svg class="w-8 h-8 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                    </svg>
                                    <span class="text-[10px]">@Path.GetExtension(item.FileName).ToUpperInvariant()</span>
                                </div>
                            }
                            <div class="absolute bottom-0 inset-x-0 bg-black/60 text-white text-[10px] px-1.5 py-1 truncate opacity-0 group-hover:opacity-100 transition-opacity">
                                @item.FileName
                            </div>
                            @if (isSelected)
                            {
                                <div class="absolute top-1 right-1 bg-brand-blue text-white rounded-full w-5 h-5 flex items-center justify-center">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                            }
                        </button>
                    }
                </div>
            }
            else if (!uploading)
            {
                <div class="text-center py-10 text-gray-400 text-sm">
                    No media files yet. Upload one above.
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 bg-gray-50 rounded-b-xl shrink-0">
            <div class="text-xs text-gray-500 truncate max-w-xs">
                @if (!string.IsNullOrEmpty(selectedUrl))
                {
                    <span>Selected: <span class="font-mono text-brand-blue">@selectedUrl</span></span>
                }
                else
                {
                    <span>Click a file to select it</span>
                }
            </div>
            <div class="flex gap-2">
                <button @onclick="ClearSelection" type="button"
                        class="text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded border border-gray-300">
                    Clear
                </button>
                <button @onclick="Confirm" type="button"
                        class="text-sm text-white bg-brand-blue px-4 py-1.5 rounded font-medium hover:opacity-90 transition-opacity disabled:opacity-50"
                        disabled="@string.IsNullOrEmpty(selectedUrl)">
                    Select
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string? CurrentUrl { get; set; }
    [Parameter] public EventCallback<string> OnSelected { get; set; }

    private List<Media> mediaItems = [];
    private string? selectedUrl;
    private string? uploadMessage;
    private bool uploadError;
    private bool uploading;
    private bool loaded;
    private long cacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !loaded)
        {
            mediaItems = await MediaService.GetAllAsync(pageSize: 200);
            selectedUrl = CurrentUrl;
            loaded = true;
        }
        else if (!IsVisible)
        {
            loaded = false;
        }
    }

    private void SelectItem(Media item)
    {
        selectedUrl = item.Url;
    }

    private async Task Confirm()
    {
        if (!string.IsNullOrEmpty(selectedUrl))
        {
            await OnSelected.InvokeAsync(selectedUrl);
        }
        await Close();
    }

    private async Task ClearSelection()
    {
        selectedUrl = null;
        await OnSelected.InvokeAsync("");
        await Close();
    }

    private async Task Close()
    {
        IsVisible = false;
        loaded = false;
        uploadMessage = null;
        uploading = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleUpload(InputFileChangeEventArgs e)
    {
        try
        {
            uploading = true;
            uploadError = false;
            uploadMessage = null;
            StateHasChanged();

            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var media = await MediaService.UploadAsync(stream, file.Name, file.ContentType);
            mediaItems = await MediaService.GetAllAsync(pageSize: 200);
            cacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            selectedUrl = media.Url;
            uploadMessage = $"Uploaded {file.Name}";
            uploading = false;
        }
        catch (Exception ex)
        {
            uploadError = true;
            uploadMessage = $"Upload failed: {ex.Message}";
            uploading = false;
        }
    }
}
